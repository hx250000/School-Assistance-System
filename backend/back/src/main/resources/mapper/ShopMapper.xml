<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.back.mapper.ShopMapper">

    <select id="listItems" resultType="org.example.back.entity.ShopItem">
        SELECT * FROM shop_item
    </select>

    <select id="getById" resultType="org.example.back.entity.ShopItem">
        SELECT * FROM shop_item WHERE id = #{itemId}
    </select>

    <insert id="insertOrder">
        INSERT INTO shop_order (user_id, item_id, status)
        VALUES (#{userId}, #{itemId}, #{status})
    </insert>

    <update id="updateStock">
        UPDATE shop_item
        SET stock = stock - 1
        WHERE id = #{itemId} AND stock > 0
    </update>

</mapper>