<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- ================= 顶部渐变 ================= -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="28dp"
        android:background="@drawable/bg_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CampusTask"
            android:textSize="26sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="校园互助的小天地"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"/>

        <!-- 搜索框 -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_search"
            android:hint="搜索你想要的任务..."
            android:paddingStart="16dp"
            android:textColor="@color/text_body"
            android:textColorHint="@color/text_hint"/>

        <!-- 数据卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <!-- 卡片1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_small"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/inprogress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="进行中"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- 卡片2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_small"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/finished"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="156"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已完成"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- 卡片3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_small"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/users"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="89"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="用户数"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ================= 分类卡片 ================= -->
    <LinearLayout
        android:id="@+id/tab_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_tab_card"
        android:elevation="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:translationY="-16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/tab_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tab_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ 全部"
                    android:padding="10dp"
                    android:background="@drawable/bg_tab_selected"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tab_game"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎮 游戏"
                    android:padding="10dp"
                    android:background="@drawable/bg_tab"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tab_life"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌸 生活"
                    android:padding="10dp"
                    android:background="@drawable/bg_tab"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tab_study"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 学习"
                    android:padding="10dp"
                    android:background="@drawable/bg_tab"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 标题 -->
    <TextView
        android:id="@+id/title_all"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="全部任务"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_body"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tab_card"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/title_all"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>