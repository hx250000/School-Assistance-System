<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- ===== 顶部渐变 ===== -->
    <LinearLayout
        android:id="@+id/top_bg"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_circle"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous" />

        <!-- 标签 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:padding="10dp"
            android:background="@drawable/bg_tag_purple"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎮 游戏任务"
                android:textColor="@color/text_on_primary"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ===== 主卡片 ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/main_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bg"
        android:layout_margin="-20dp"
        android:layout_marginTop="-80dp"
        android:layout_marginBottom="120dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- 标题 -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="王者荣耀开黑"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_title" />

            <!-- 描述卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:padding="14dp"
                android:background="@drawable/bg_soft_card"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ 任务描述"
                    android:textColor="@color/purple_500"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="需要两个队友一起打排位，最好是铂金以上段位"
                    android:textColor="@color/text_body" />
            </LinearLayout>

            <!-- 信息块 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <!-- 第一行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <include layout="@layout/item_info_card"
                        android:id="@+id/card_people"/>

                    <include layout="@layout/item_info_card"
                        android:id="@+id/card_score"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <include layout="@layout/item_info_card"
                        android:id="@+id/card_time"/>

                    <include layout="@layout/item_info_card"
                        android:id="@+id/card_deadline"/>

                </LinearLayout>

            </LinearLayout>

            <!-- 发布者 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@mipmap/ic_launcher"
                    android:background="@drawable/bg_circle" />

                <LinearLayout
                    android:layout_marginStart="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="任务发布者"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="李四"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_title"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== 底部按钮 ===== -->
    <Button
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🚀 立即抢任务 +20积分"
        android:textColor="@color/text_on_primary"
        android:textSize="16sp"
        android:background="@drawable/bg_gradient"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"/>

</RelativeLayout>