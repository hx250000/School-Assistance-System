<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_gradient"
            android:padding="24dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="发布任务"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="让小伙伴来帮你吧 ✨"
                android:textColor="#EAEAEA"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- 卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_content"
            android:padding="18dp"
            android:elevation="6dp"
            android:orientation="vertical">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="任务标题"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:hint="给任务起个吸引人的标题"
                android:paddingHorizontal="14dp"
                android:layout_marginTop="6dp"/>

            <!-- 类型 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="任务类型"
                android:textStyle="bold"
                android:layout_marginTop="18dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/type1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="生活"
                    android:background="@drawable/bg_tag_selected"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/type2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="学习"
                    android:background="@drawable/bg_tag"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/type3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="游戏"
                    android:background="@drawable/bg_tag"/>
            </LinearLayout>

            <!-- 人数 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="需要人数"
                android:textStyle="bold"/>

            <!-- 截止时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <Button
                    android:id="@+id/btn_minus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="-" />

                <EditText
                    android:id="@+id/et_people"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="center"
                    android:text="1" />

                <Button
                    android:id="@+id/btn_add"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="截止时间"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/et_deadline"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:text="请选择截止时间"
                android:textColor="@android:color/black"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 积分 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="奖励积分"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰"
                    android:layout_marginEnd="6dp"/>

                <EditText
                    android:id="@+id/et_score"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="输入奖励积分"
                    android:background="@null"
                    android:inputType="number"/>
            </LinearLayout>

            <!-- ================= 任务描述（已优化AI按钮） ================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="任务描述"
                android:textStyle="bold"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="6dp">

                <EditText
                    android:id="@+id/et_desc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input"
                    android:hint="详细描述任务"
                    android:padding="12dp"
                    android:gravity="top"/>

                <!-- ⭐ 小AI按钮 -->
                <TextView
                    android:id="@+id/btn_ai_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_gravity="end|top"
                    android:layout_margin="8dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="AI"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_gradient"/>
            </FrameLayout>

            <!-- 发布按钮 -->
            <Button
                android:id="@+id/btn_publish"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✨ 发布任务"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_btn_gradient"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>